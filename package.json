{
  "name": "@useago/sdk",
  "version": "1.3.0",
  "description": "Create In-APP AI agents that answers question and performs actions. Works with React, Vue, Angular and vanilla JS/TS.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue.d.ts",
        "default": "./dist/vue.js"
      },
      "require": {
        "types": "./dist/vue.d.cts",
        "default": "./dist/vue.cjs"
      }
    },
    "./angular": {
      "import": {
        "types": "./dist/angular.d.ts",
        "default": "./dist/angular.js"
      },
      "require": {
        "types": "./dist/angular.d.cts",
        "default": "./dist/angular.cjs"
      }
    },
    "./helpers": {
      "import": {
        "types": "./dist/helpers.d.ts",
        "default": "./dist/helpers.js"
      },
      "require": {
        "types": "./dist/helpers.d.cts",
        "default": "./dist/helpers.cjs"
      }
    },
    "./widget": {
      "import": {
        "types": "./dist/widget.d.ts",
        "default": "./dist/widget.js"
      },
      "require": {
        "types": "./dist/widget.d.cts",
        "default": "./dist/widget.cjs"
      }
    },
    "./devtools": {
      "import": {
        "types": "./dist/devtools.d.ts",
        "default": "./dist/devtools.js"
      },
      "require": {
        "types": "./dist/devtools.d.cts",
        "default": "./dist/devtools.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useago/ago-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/useago/ago-sdk/issues"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && vite build && npm run build:cts-types",
    "build:cts-types": "for f in $(find dist -name '*.d.ts'); do cp \"$f\" \"${f%.d.ts}.d.cts\"; done",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build && npm run check:package",
    "check:package": "publint --strict && attw --pack . --profile node16",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^28.0.0",
    "publint": "^0.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.0",
    "vue": "^3.5.32"
  },
  "keywords": [
    "ago",
    "chat",
    "sdk",
    "ai",
    "ai-agent",
    "agent",
    "llm",
    "assistant",
    "chatbot",
    "streaming",
    "function-calling",
    "react",
    "vue",
    "angular"
  ],
  "license": "Apache-2.0",
  "homepage": "https://useago.com"
}
